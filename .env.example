# ==========================================
# DISCORD BOT CONFIGURATION
# ==========================================

# Your Discord bot token (keep this private)
DISCORD_TOKEN=YOUR_BOT_TOKEN_HERE

# Application (Client) ID from Discord Developer Portal
CLIENT_ID=YOUR_CLIENT_ID_HERE


# ==========================================
# DATABASE CONFIGURATION (MONGODB)
# ==========================================

# MongoDB connection string (Atlas or local instance)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/database_name


# ==========================================
# OPTIONAL SETTINGS
# ==========================================

# Command prefix (only required if prefix commands are enabled)
PREFIX=
